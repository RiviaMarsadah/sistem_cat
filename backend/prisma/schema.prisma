// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  guru
  siswa
}

enum UserStatus {
  aktif
  nonaktif
}

enum KelasTingkat {
  X
  XI
  XII
}

/// Untuk bank_soal: X, XI, XII, atau SEMUA (soal dipakai semua tingkat).
/// Di DB nilai "SEMUA" disimpan; frontend bisa kirim "0" yang dipetakan ke SEMUA.
enum TingkatSoal {
  X
  XI
  XII
  SEMUA
}

enum TipeUjian {
  UH
  UTS
  UAS
  Lainnya
}

enum JenisKelamin {
  L
  P
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique @db.VarChar(100)
  password     String?    @db.VarChar(255)
  role         UserRole
  namaLengkap  String     @map("nama_lengkap") @db.VarChar(100)
  status       UserStatus @default(aktif)
  googleId     String?    @unique @map("google_id") @db.VarChar(255)
  googlePicture String?   @map("google_picture") @db.VarChar(500)
  googleLinked Boolean    @default(false) @map("google_linked")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  guru   Guru?
  siswa  Siswa?

  @@map("users")
}

model Guru {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  nip       String?  @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankSoal     BankSoal[]
  paketUjian   PaketUjian[]

  @@map("guru")
}

model Siswa {
  id          Int          @id @default(autoincrement())
  userId      Int          @unique @map("user_id")
  nis         String?      @unique @db.VarChar(20)
  nisn        String?      @unique @db.VarChar(20)
  kelasId     Int?         @map("kelas_id")
  noTelp      String?      @map("no_telp") @db.VarChar(20)
  jenisKelamin JenisKelamin? @map("jenis_kelamin")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kelas Kelas? @relation(fields: [kelasId], references: [id])

  @@map("siswa")
}

enum KategoriSoal {
  single_choice
  multi_choice
  benar_salah
}

enum KategoriMapel {
  prodi
  muatan_lokal
}

model MataPelajaran {
  id         Int            @id @default(autoincrement())
  namaMapel  String         @map("nama_mapel") @db.VarChar(100)
  kodeMapel  String?        @unique @map("kode_mapel") @db.VarChar(20)
  deskripsi  String?        @db.Text
  kategori   KategoriMapel  @default(prodi)
  jurusanId  Int?           @map("jurusan_id")
  createdAt  DateTime       @default(now()) @map("created_at")

  jurusan     Jurusan?     @relation(fields: [jurusanId], references: [id], onDelete: SetNull)
  bankSoal    BankSoal[]
  paketUjian  PaketUjian[]

  @@map("mata_pelajaran")
}

model Kelas {
  id        Int          @id @default(autoincrement())
  namaKelas String       @map("nama_kelas") @db.VarChar(50)
  tingkat   KelasTingkat
  jurusanId Int          @map("jurusan_id")
  inisial   String       @db.VarChar(10)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  // Relations
  siswa   Siswa[]
  jurusan Jurusan  @relation(fields: [jurusanId], references: [id])

  @@unique([tingkat, jurusanId, inisial])
  @@map("kelas")
}

model Jurusan {
  id        Int      @id @default(autoincrement())
  idJurusan String   @unique @map("id_jurusan") @db.VarChar(20)
  nama      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  kelas          Kelas[]
  mataPelajaran MataPelajaran[]
  bankSoal       BankSoal[]

  @@map("jurusan")
}

model BankSoal {
  id                Int          @id @default(autoincrement())
  mataPelajaranId   Int          @map("mata_pelajaran_id")
  tingkat           TingkatSoal
  jurusanId         Int?         @map("jurusan_id")
  guruId            Int          @map("guru_id")
  kategoriSoal      KategoriSoal @map("kategori_soal")
  soal              String?      @db.Text
  kolomA            String?      @map("kolom_a") @db.VarChar(500)
  kolomB            String?      @map("kolom_b") @db.VarChar(500)
  kolomC            String?      @map("kolom_c") @db.VarChar(500)
  kolomD            String?      @map("kolom_d") @db.VarChar(500)
  kolomE            String?      @map("kolom_e") @db.VarChar(500)
  kolomF            String?      @map("kolom_f") @db.VarChar(500)
  jawaban           String       @db.VarChar(100)
  gambar            String?      @db.VarChar(500)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  mataPelajaran MataPelajaran   @relation(fields: [mataPelajaranId], references: [id], onDelete: Cascade)
  jurusan       Jurusan?       @relation(fields: [jurusanId], references: [id], onDelete: SetNull)
  guru          Guru            @relation(fields: [guruId], references: [id], onDelete: Cascade)
  soalPaketUjian SoalPaketUjian[]

  @@map("bank_soal")
}

model PaketUjian {
  id                Int       @id @default(autoincrement())
  nama              String    @map("nama") @db.VarChar(200)
  mataPelajaranId   Int       @map("mata_pelajaran_id")
  tingkat           TingkatSoal
  tipeUjian         TipeUjian @map("tipe_ujian")
  tokenCheckIn      String    @map("token_checkin") @db.VarChar(6)
  tokenCheckOut     String    @map("token_checkout") @db.VarChar(6)
  guruId            Int       @map("guru_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  mataPelajaran MataPelajaran   @relation(fields: [mataPelajaranId], references: [id], onDelete: Cascade)
  guru          Guru            @relation(fields: [guruId], references: [id], onDelete: Cascade)
  soalPaket     SoalPaketUjian[]

  @@map("paket_ujian")
}

model SoalPaketUjian {
  id             Int       @id @default(autoincrement())
  paketUjianId   Int       @map("paket_ujian_id")
  bankSoalId     Int       @map("bank_soal_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  paketUjian PaketUjian @relation(fields: [paketUjianId], references: [id], onDelete: Cascade)
  bankSoal   BankSoal  @relation(fields: [bankSoalId], references: [id], onDelete: Cascade)

  @@unique([paketUjianId, bankSoalId])
  @@map("soal_paket_ujian")
}
